# Example build.env for SmoothNAS.
# Copy to ../build.env and adjust paths for your dev machine.

KERNEL_VERSION=6.18.22
LOCALVERSION=-smoothnas-lts
ZFS_VERSION=2.4.1

# Path to the seed .config — copy from a known-good SmoothNAS appliance:
#   ssh smoothnas 'cat /boot/config-$(uname -r)' > /tmp/smoothnas-seed.config
CONFIG_SOURCE=/tmp/smoothnas-seed.config

# Where the .debs land. Default is $(pwd)/out.
OUT_DIR=/tmp/smoothnas-out

# Build parallelism. Default is $(nproc).
BUILD_THREADS=14

# Strip BTF/DWARF debug info to slim the kernel image and speed up
# packaging. Set to 0 if you want full debug info.
STRIP_DEBUG_INFO=1

# NAS / server network-path tuning. Enables BBR + FQ as built-in, flips
# the default TCP congestion control to BBR, enables NET_RX_BUSY_POLL +
# TCP_MD5SIG + TCP_CONG_DCTCP + NF_CONNTRACK_FLOW_TABLE. Paired with
# /etc/sysctl.d drop-ins in the SmoothNAS image. Set to 0 to build a
# reference kernel that matches upstream Debian defaults (e.g. to
# reproduce a Debian-side bug).
NET_TUNING=1

# Server / appliance general tuning. Enables PREEMPT_DYNAMIC,
# RCU_NOCB_CPU, and BLK_WBT_MQ. None of these change behaviour without
# corresponding cmdline / sysctl setup, so compiling them in is cheap.
SERVER_TUNING=1
