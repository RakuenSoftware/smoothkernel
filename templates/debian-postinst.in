#!/bin/sh
# Debian postinst hook for an out-of-tree module shipped via DKMS.
# Substitute @MODULE_NAME@ and @MODULE_VERSION@ at install time.

set -e

PACKAGE_NAME="@MODULE_NAME@"
PACKAGE_VERSION="@MODULE_VERSION@"

case "$1" in
configure)
	if ! command -v dkms >/dev/null 2>&1; then
		echo "${PACKAGE_NAME}: dkms is not installed; skipping module build" >&2
		exit 0
	fi
	if dkms status -m "$PACKAGE_NAME" -v "$PACKAGE_VERSION" \
		2>/dev/null | grep -q installed; then
		exit 0
	fi
	dkms add     -m "$PACKAGE_NAME" -v "$PACKAGE_VERSION" || true
	dkms build   -m "$PACKAGE_NAME" -v "$PACKAGE_VERSION"
	dkms install -m "$PACKAGE_NAME" -v "$PACKAGE_VERSION" --force
	if ! lsmod | grep -q "^${PACKAGE_NAME} "; then
		modprobe "$PACKAGE_NAME" || true
	fi
	;;
esac

exit 0
